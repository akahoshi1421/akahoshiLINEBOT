{
  "compilerOptions": {
    "target": "es2015",
    "module": "esnext",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "types": ["google-apps-script"]
  },
  "include": ["./src/**/*"]
}
