generator client {
  provider = "prisma-client-js"
  output   = "./src/generated/gassma"
}

/// スケジュール一覧シート
model Schedule {
  id           Int           @id @default(autoincrement())
  eventName    String        @map("イベント名")
  eventDate    DateTime?     @map("集合時間")
  remarks      String?       @map("備考")
  participants Participant[]

  @@map("スケジュール一覧")
}

/// 参加者シート（スケジュールに対して多）
model Participant {
  scheduleId Int      @map("イベントid")
  name       String   @map("参加者名")
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@id([scheduleId, name])
  @@map("参加者")
}
